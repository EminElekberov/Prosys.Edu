@{
    var usertypes = ((IEnumerable<SelectListItem>)ViewBag.usertypes)
   .Select(s => $"<option value=\"{s.Value}\">{s.Text}</option>")
   .ToList();

    var userclass = ((IEnumerable<SelectListItem>)ViewBag.userclass)
   .Select(s => $"<option value=\"{s.Value}\">{s.Text}</option>")
   .ToList();
}
<div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 14px;">

            <div class="modal-header border-bottom-0 pb-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                <h5 class="modal-title fw-bold text-dark" id="addUserModalLabel">
                    <i class="fa-solid fa-user-plus text-primary me-2"></i> Yeni İstifadəçi Profili
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Bağla"></button>
            </div>

            <form id="createUserForm" onsubmit="submitUserForm(event)">
                <div class="modal-body p-4">

                    <!-- Ad İnpudu -->
                    <div class="mb-3">
                        <label for="firstName" class="form-label small fw-semibold text-secondary">Adı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control border-light-subtle py-2 rounded-3" id="firstName" required placeholder="Məs: Əli" autocomplete="off">
                    </div>

                    <!-- Soyad İnpudu -->
                    <div class="mb-3">
                        <label for="lastName" class="form-label small fw-semibold text-secondary">Soyadı <span class="text-danger">*</span></label>
                        <input type="text" class="form-control border-light-subtle py-2 rounded-3" id="lastName" required placeholder="Məs: Məmmədov" autocomplete="off">
                    </div>

                    <!-- Dynamic İstifadəçi Tipi Seçimi -->
                    <div class="mb-2">
                        <label for="userTypeCode" class="form-label small fw-semibold text-secondary">İstifadəçi Tipi (Rol) <span class="text-danger">*</span></label>
                        <select class="form-select border-light-subtle py-2 rounded-3" id="userTypeCode" required>
                            @Html.Raw(string.Join("", usertypes))

                        </select>
                    </div>


                    <div class="mb-2">
                        <label for="userClassCode" class="form-label small fw-semibold text-secondary">Sinifi <span class="text-danger">*</span></label>
                        <select class="form-select border-light-subtle py-2 rounded-3" id="userClassCode" required>
                            @Html.Raw(string.Join("", userclass))

                        </select>
                    </div>

                </div>

                <div class="modal-footer border-top-0 pt-0 pb-4 px-4">
                    <button type="button" class="btn btn-light px-3 py-2 rounded-3 text-secondary fw-medium small" data-bs-dismiss="modal">Ləğv et</button>
                    <button type="submit" class="btn btn-primary px-4 py-2 rounded-3 fw-medium small shadow-sm">
                        <i class="fa-solid fa-check me-1"></i> Yadda saxla
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

<script>
    function submitUserForm(e) {
        e.preventDefault();

        // Tam sənin istədiyin model strukturu yığılır
        var userModel = {
            Name: $('#firstName').val(),
            Surname: $('#lastName').val(),
            UserTypeId: $('#userTypeCode').val(),
            UserClassId: $('#userClassCode').val()

        };

        $.ajax({
            url: '/User/Create',
            type: 'POST',
            data: userModel,
            success: function (response) {
                if (response.success) {
                    var modalEl = document.getElementById('addUserModal');
                    var modalInstance = bootstrap.Modal.getInstance(modalEl);
                    if (modalInstance) modalInstance.hide();

                    alert(response.message || 'İstifadəçi uğurla yaradıldı!');
                    location.reload();
                } else {
                    alert('Xəta: ' + response.message);
                }
            },
            error: function () {
                alert('Məlumat qeyd edilərkən server xətası baş verdi.');
            }
        });
    }
</script>